<mujoco model="MediPick_Scene">
  <!-- 主文件全局设置，子文件的compiler会自动合并，冲突时主文件优先 -->

  <option gravity="0 0 -9.81" timestep="0.002" cone="elliptic" impratio="10"/>

  <!-- 关键1：先include所有子文件，必须放在mujoco根下，和worldbody同级 -->

  <include file="shelves/middle_4.xml"/>
  <include file="simple3/urdf/simple3_test2_include.xml"/>
  <visual>
  <headlight ambient="0.5 0.5 0.5" diffuse="0.5 0.5 0.5" specular="0 0 0"/>
  </visual>
  <!-- 世界本体，在这里重写根body的位置 -->
  <worldbody>
    <!-- 环境光 -->
    
    <geom name="floor" type="plane" pos="0 0 0" size="5 5 0.01" rgba="0.4 0.4 0.4 1"/>
    <site name="entry_plane" 
      type="box" 
      size="0.44 0.001 0.5" 
      pos="1.375 -1.85 0.6" 
      rgba="1 0 0 0.3" />
      
    <!-- 摄像头设置：对着机器人和货架 -->
    <camera name="fixed" pos="1.5 -1.0 1.5" xyaxes="0 1 0 -1 0 1" mode="fixed"/>

<body name="pill_box" pos="1.375 -1.66 0.726">
    <!-- 药盒保持freejoint，但在reset时固定位置 -->
    <freejoint name="box_root"/>
    
    <geom name="box_geom" 
          type="box" 
          size="0.06 0.01 0.035" 
          mass="0.2" 
          rgba="0.2 0.8 0.2 1"/>
          
    <site name="box_front_center" 
          pos="0 -0.01 0" 
          size="0.005" 
          rgba="1 1 0 1"/>

    <site name="upper_limit" 
          pos="0 0 0.21" 
          size="0.01" 
          rgba="0 0 1 0.2"/> 

    <site name="lower_limit" 
          pos="0 0 -0.035" 
          size="0.01" 
          rgba="0 0 1 0.2"/>
</body>
  



  </worldbody>
</mujoco>